config global 'settings'
	option enabled '0'
	option reload_nginx '1'
	option http_include_dir '/etc/nginx/conf.d'
	option stream_include_dir '/etc/nginx/stream.d'

config http_host
	option enabled '1'
	option name 'webapp'
	option domain 'app.example.com'
	option listen_http '1'
	option listen_https '1'
	option tls_cert '/etc/nginx/certs/app.example.com.crt'
	option tls_key '/etc/nginx/certs/app.example.com.key'
	option upstream_scheme 'https'
	option upstream_target 'manual'
	option upstream_host '10.0.0.10'
	option upstream_port '8443'
	option upstream_sni 'app.internal.example'
	option upstream_ca '/etc/ssl/certs/internal-ca.pem'

config stream_host
	option enabled '1'
	option name 'smtp-submission'
	option listen_addr '0.0.0.0'
	option listen_port '465'
	option upstream_target 'manual'
	option upstream_host '10.0.0.20'
	option upstream_port '465'
