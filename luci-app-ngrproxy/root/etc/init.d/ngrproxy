#!/bin/sh /etc/rc.common

START=91
STOP=10
USE_PROCD=1

render_config() {
	/usr/libexec/ngrproxy/render.sh
}

service_triggers() {
	procd_add_reload_trigger "ngrproxy"
}

start_service() {
	local enabled reload_nginx
	enabled="$(uci -q get ngrproxy.settings.enabled)"
	[ "$enabled" = "1" ] || return 0

	render_config || return 1
	reload_nginx="$(uci -q get ngrproxy.settings.reload_nginx)"
	[ "$reload_nginx" = "1" ] || return 0
	/etc/init.d/nginx reload >/dev/null 2>&1 || /etc/init.d/nginx restart >/dev/null 2>&1
}

reload_service() {
	start_service
}

stop_service() {
	return 0
}
